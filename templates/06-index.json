{
  "id": "index",
  "name": "Index",
  "tagline": "Sticky nav with 1:2 grid sections and masonry projects",
  "description": "Crisp and navigable. A sticky top nav anchors the page while a 1fr:2fr grid keeps every section scannable. Projects presented as masonry cards with varied aspect ratios.",
  "best_for": ["product managers", "engineers", "researchers", "generalists"],
  "preview_image": "/templates/index.png",

  "defaults": {
    "accent_color": "#2563EB",
    "color_mode": "light",
    "density": "comfortable"
  },

  "typography": {
    "heading": { "font_family": "Bricolage Grotesque", "font_weights": [600, 700], "font_size_pt": 13, "line_height": 1.05, "letter_spacing_em": -0.02 },
    "body": { "font_family": "Inter", "font_weights": [400, 500], "font_size_pt": 10.5, "line_height": 1.6, "letter_spacing_em": 0 },
    "mono": { "font_family": "JetBrains Mono", "font_weights": [400], "font_size_pt": 9, "line_height": 1.5 }
  },

  "layout": {
    "kind": "nav-grid",
    "container_max_px": 1120,
    "section_gap_px": 80,
    "page_padding_x_px": 40,
    "page_padding_y_px": 80
  },

  "tokens": {
    "background": "#FAFAF7",
    "surface": "#FFFFFF",
    "ink": "#1A1916",
    "ink_muted": "#6B6960",
    "border": "#E8E4DC",
    "radius_card_px": 8,
    "radius_button_px": 6,
    "radius_image_px": 6
  },

  "sections": [
    { "id": "hero",       "type": "hero",       "layout": "nav-hero",     "visible": true, "order": 0 },
    { "id": "projects",   "type": "projects",   "layout": "masonry",      "visible": true, "order": 1 },
    { "id": "about",      "type": "about",      "layout": "grid-prose",   "visible": true, "order": 2 },
    { "id": "experience", "type": "experience", "layout": "grid-timeline","visible": true, "order": 3 },
    { "id": "education",  "type": "education",  "layout": "grid-compact", "visible": true, "order": 4 },
    { "id": "skills",     "type": "skills",     "layout": "grid-tags",    "visible": true, "order": 5 },
    { "id": "contact",    "type": "contact",    "layout": "grid-contact", "visible": true, "order": 999 }
  ]
}
