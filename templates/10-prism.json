{
  "id": "prism",
  "name": "Prism",
  "tagline": "Sandy background with sticky nav and bold hero headline",
  "description": "Prism refracts your identity into a single bold headline. Sandy warm background, sticky nav, giant display headline, and a clean project grid. Straightforward, confident, memorable.",
  "best_for": ["frontend engineers", "design engineers", "UI engineers", "product engineers"],
  "preview_image": "/templates/prism.png",

  "defaults": {
    "accent_color": "#5E32E0",
    "color_mode": "light",
    "density": "comfortable"
  },

  "typography": {
    "heading": { "font_family": "Bricolage Grotesque", "font_weights": [600, 700], "font_size_pt": 14, "line_height": 1.05, "letter_spacing_em": -0.02 },
    "body": { "font_family": "Inter", "font_weights": [400, 500], "font_size_pt": 10.5, "line_height": 1.6, "letter_spacing_em": 0 },
    "mono": { "font_family": "JetBrains Mono", "font_weights": [400, 500], "font_size_pt": 9, "line_height": 1.5 }
  },

  "layout": {
    "kind": "nav-single-column",
    "container_max_px": 1400,
    "section_gap_px": 80,
    "page_padding_x_px": 40,
    "page_padding_y_px": 96
  },

  "tokens": {
    "background": "#F1EEE6",
    "surface": "#FAFAF6",
    "ink": "#0F0E0B",
    "ink_muted": "#54514A",
    "border": "#E1DDC8",
    "radius_card_px": 10,
    "radius_button_px": 6,
    "radius_image_px": 8
  },

  "sections": [
    { "id": "hero",       "type": "hero",       "layout": "nav-hero",      "visible": true, "order": 0 },
    { "id": "projects",   "type": "projects",   "layout": "card-grid",     "visible": true, "order": 1 },
    { "id": "about",      "type": "about",      "layout": "prose",         "visible": true, "order": 2 },
    { "id": "experience", "type": "experience", "layout": "timeline",      "visible": true, "order": 3 },
    { "id": "education",  "type": "education",  "layout": "compact",       "visible": true, "order": 4 },
    { "id": "skills",     "type": "skills",     "layout": "tag-cloud",     "visible": true, "order": 5 },
    { "id": "contact",    "type": "contact",    "layout": "centered",      "visible": true, "order": 999 }
  ]
}
