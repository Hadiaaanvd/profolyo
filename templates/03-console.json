{
  "id": "console",
  "name": "Console",
  "tagline": "Terminal-inspired dark portfolio for developers",
  "description": "Your career as a command-line session. Dark navy background, monospaced type throughout, experience as git log, projects as numbered paths. Built for engineers who think in code.",
  "best_for": ["software engineers", "devtools builders", "open-source contributors", "platform engineers"],
  "preview_image": "/templates/console.png",

  "defaults": {
    "accent_color": "#7BE38C",
    "color_mode": "dark",
    "density": "comfortable"
  },

  "typography": {
    "heading": { "font_family": "JetBrains Mono", "font_weights": [600, 700], "font_size_pt": 13, "line_height": 1.3, "letter_spacing_em": -0.01 },
    "body": { "font_family": "JetBrains Mono", "font_weights": [400, 500], "font_size_pt": 10, "line_height": 1.65, "letter_spacing_em": 0 },
    "mono": { "font_family": "JetBrains Mono", "font_weights": [400, 500], "font_size_pt": 10, "line_height": 1.5 }
  },

  "layout": {
    "kind": "single-column",
    "container_max_px": 820,
    "section_gap_px": 72,
    "page_padding_x_px": 32,
    "page_padding_y_px": 80
  },

  "tokens": {
    "background": "#0B1020",
    "surface": "#111827",
    "ink": "#E8EAF0",
    "ink_muted": "#6B7280",
    "border": "#1F2937",
    "radius_card_px": 8,
    "radius_button_px": 4,
    "radius_image_px": 6
  },

  "sections": [
    { "id": "hero",       "type": "hero",       "layout": "terminal-hero", "visible": true, "order": 0 },
    { "id": "projects",   "type": "projects",   "layout": "terminal-list", "visible": true, "order": 1 },
    { "id": "experience", "type": "experience", "layout": "git-log",       "visible": true, "order": 2 },
    { "id": "education",  "type": "education",  "layout": "json-block",    "visible": true, "order": 3 },
    { "id": "skills",     "type": "skills",     "layout": "code-list",     "visible": true, "order": 4 },
    { "id": "contact",    "type": "contact",    "layout": "terminal-cmd",  "visible": true, "order": 999 }
  ]
}
