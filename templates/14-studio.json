{
  "id": "studio",
  "name": "Studio",
  "tagline": "Off-white studio with alternating project spreads",
  "description": "The studio aesthetic: 80px name header, alternating image-left/image-right project cards with big watermark numbers, and a clean testimonials dark block. Professional, considered, warm.",
  "best_for": ["UX designers", "product designers", "design leads", "creative directors"],
  "preview_image": "/templates/studio.png",

  "defaults": {
    "accent_color": "#2D6A4F",
    "color_mode": "light",
    "density": "spacious"
  },

  "typography": {
    "heading": { "font_family": "Bricolage Grotesque", "font_weights": [600, 700], "font_size_pt": 15, "line_height": 1.0, "letter_spacing_em": -0.03 },
    "body": { "font_family": "Inter", "font_weights": [400, 500], "font_size_pt": 10.5, "line_height": 1.6, "letter_spacing_em": 0 },
    "mono": { "font_family": "JetBrains Mono", "font_weights": [400], "font_size_pt": 9, "line_height": 1.5 }
  },

  "layout": {
    "kind": "full-width",
    "container_max_px": 1240,
    "section_gap_px": 96,
    "page_padding_x_px": 48,
    "page_padding_y_px": 72
  },

  "tokens": {
    "background": "#F6F5F1",
    "surface": "#FFFFFF",
    "ink": "#1A1916",
    "ink_muted": "#706D64",
    "border": "#E8E4DC",
    "radius_card_px": 0,
    "radius_button_px": 4,
    "radius_image_px": 0
  },

  "sections": [
    { "id": "hero",         "type": "hero",         "layout": "studio-header",   "visible": true,  "order": 0 },
    { "id": "projects",     "type": "projects",     "layout": "alternating",     "visible": true,  "order": 1 },
    { "id": "about",        "type": "about",        "layout": "two-col",         "visible": true,  "order": 2 },
    { "id": "experience",   "type": "experience",   "layout": "two-col",         "visible": true,  "order": 3 },
    { "id": "education",    "type": "education",    "layout": "two-col",         "visible": true,  "order": 4 },
    { "id": "skills",       "type": "skills",       "layout": "tag-cloud",       "visible": true,  "order": 5 },
    { "id": "testimonials", "type": "testimonials", "layout": "dark-block",      "visible": true,  "order": 6 },
    { "id": "contact",      "type": "contact",      "layout": "centered",        "visible": true,  "order": 999 }
  ]
}
