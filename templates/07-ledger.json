{
  "id": "ledger",
  "name": "Ledger",
  "tagline": "Warm editorial with Source Serif 4 and date-grid layout",
  "description": "An editorial ledger: every entry has a date in the left margin and content in the right. Source Serif 4 gives it literary warmth. For thinkers, writers, and researchers.",
  "best_for": ["researchers", "writers", "academics", "designers who write"],
  "preview_image": "/templates/ledger.png",

  "defaults": {
    "accent_color": "#B7410E",
    "color_mode": "light",
    "density": "spacious"
  },

  "typography": {
    "heading": { "font_family": "Source Serif 4", "font_weights": [600, 700], "font_size_pt": 14, "line_height": 1.1, "letter_spacing_em": -0.01 },
    "body": { "font_family": "Inter", "font_weights": [400, 500], "font_size_pt": 10.5, "line_height": 1.65, "letter_spacing_em": 0 },
    "mono": { "font_family": "JetBrains Mono", "font_weights": [400], "font_size_pt": 9, "line_height": 1.5 }
  },

  "layout": {
    "kind": "single-column",
    "container_max_px": 760,
    "section_gap_px": 80,
    "page_padding_x_px": 32,
    "page_padding_y_px": 88
  },

  "tokens": {
    "background": "#F7F5F0",
    "surface": "#FFFFFF",
    "ink": "#1C1916",
    "ink_muted": "#7A7670",
    "border": "#E4E0D8",
    "radius_card_px": 4,
    "radius_button_px": 4,
    "radius_image_px": 4
  },

  "sections": [
    { "id": "hero",         "type": "hero",         "layout": "editorial-hero",  "visible": true,  "order": 0 },
    { "id": "about",        "type": "about",        "layout": "ledger-prose",    "visible": true,  "order": 1 },
    { "id": "projects",     "type": "projects",     "layout": "ledger-rows",     "visible": true,  "order": 2 },
    { "id": "experience",   "type": "experience",   "layout": "date-grid",       "visible": true,  "order": 3 },
    { "id": "education",    "type": "education",    "layout": "date-grid",       "visible": true,  "order": 4 },
    { "id": "publications", "type": "publications", "layout": "ledger-rows",     "visible": true,  "order": 5 },
    { "id": "skills",       "type": "skills",       "layout": "inline-list",     "visible": true,  "order": 6 },
    { "id": "contact",      "type": "contact",      "layout": "ledger-contact",  "visible": true,  "order": 999 }
  ]
}
