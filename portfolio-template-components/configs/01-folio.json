{
  "id": "folio",
  "name": "Folio",
  "tagline": "Editorial portfolio for designers and design engineers",
  "description": "A magazine-feel layout: single column, generous whitespace, big display headlines, project entries arranged as horizontal magazine spreads. The work breathes.",
  "best_for": ["designers", "design engineers", "writers", "researchers"],
  "preview_image": "/templates/folio.png",

  "defaults": {
    "accent_color": "#E76F51",
    "color_mode": "light",
    "density": "spacious"
  },

  "typography": {
    "heading": {
      "font_family": "Bricolage Grotesque",
      "font_weights": [600, 700],
      "font_size_pt": 13,
      "line_height": 1.05,
      "letter_spacing_em": -0.025
    },
    "body": {
      "font_family": "Inter",
      "font_weights": [400, 500],
      "font_size_pt": 10.5,
      "line_height": 1.6,
      "letter_spacing_em": 0
    },
    "mono": {
      "font_family": "JetBrains Mono",
      "font_weights": [400, 500],
      "font_size_pt": 9.5,
      "line_height": 1.5
    }
  },

  "layout": {
    "kind": "single-column",
    "container_max_px": 880,
    "section_gap_px": 96,
    "page_padding_x_px": 32,
    "page_padding_y_px": 96
  },

  "tokens": {
    "background": "#FBF8F1",
    "surface": "#FFFFFF",
    "ink": "#1A1814",
    "ink_muted": "#6B655A",
    "border": "#E8E2D2",
    "radius_card_px": 0,
    "radius_button_px": 4,
    "radius_image_px": 6
  },

  "sections": [
    { "id": "hero",       "type": "hero",       "layout": "stacked-large",     "visible": true, "order": 1, "options": { "show_availability_pill": true, "show_avatar": false } },
    { "id": "about",      "type": "about",      "layout": "single-prose",      "visible": true, "order": 2, "options": { "max_width_ch": 64 } },
    { "id": "work",       "type": "projects",   "layout": "horizontal-rows",   "visible": true, "order": 3, "options": { "show_status": true, "show_tagline": true, "show_tech": true, "max_visible": 6, "image_position": "left" } },
    { "id": "experience", "type": "experience", "layout": "timeline",          "visible": true, "order": 4, "options": { "show_highlights": true } },
    { "id": "education",  "type": "education",  "layout": "compact-list",      "visible": true, "order": 5 },
    { "id": "skills",     "type": "skills",     "layout": "category-rows",     "visible": true, "order": 6, "options": { "style": "comma_separated" } },
    { "id": "contact",    "type": "contact",    "layout": "large-cta",         "visible": true, "order": 7, "options": { "show_socials": true } }
  ]
}
